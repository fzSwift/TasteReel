# Copy to `.env.local` (not committed). Restart Expo after any change.
#
# =============================================================================
# Path B — Live Supabase + sign-in (recommended for a real demo)
# =============================================================================
# 1) Do NOT set EXPO_PUBLIC_OFFLINE_DEMO (and do not run `npm run demo`).
# 2) Fill URL + anon (or publishable) key below — same as Supabase → Project Settings → API.
# 3) Apply `supabase/schema.sql` in Supabase SQL Editor if tables are missing.
# 4) Create users: Dashboard → Authentication → Users, OR sign up once per phone from the app.
# 5) Set roles: edit emails in `supabase/path-b-demo-roles.sql`, run that SQL (or update `profiles.role` by hand).
# 6) Start: `npx expo start --tunnel` (or `--lan` on same Wi‑Fi). Open in Expo Go → sign in with each test user.
#
# If sign-up asks for email confirmation: Dashboard → Authentication → Providers → Email
# → disable "Confirm email" for internal demos, or confirm via inbox.
#
# =============================================================================
# Path A — Offline mock demo (no login)
# =============================================================================
#   npm run demo
#   OR add: EXPO_PUBLIC_OFFLINE_DEMO=1
#
# =============================================================================
# EAS Build — environment variables on expo.dev
# =============================================================================
# EXPO_PUBLIC_* must use visibility "Plain text" or "Sensitive", never "Secret".
#   npx eas env:create --name EXPO_PUBLIC_SUPABASE_URL --value "https://xxx.supabase.co" --environment preview --visibility plaintext
#   npx eas env:create --name EXPO_PUBLIC_SUPABASE_KEY --value "eyJhbG..." --environment preview --visibility plaintext

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Anon JWT or publishable key (Dashboard → API):
EXPO_PUBLIC_SUPABASE_KEY=your_anon_or_publishable_key_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional: Cloudinary (recommended for video uploads to avoid storage streaming edge cases)
# Create an unsigned upload preset in Cloudinary and paste values below.
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
# Optional folder prefix (e.g. "menu-videos")
EXPO_PUBLIC_CLOUDINARY_FOLDER=
